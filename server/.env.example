PORT=5000
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
ALLOW_VERCEL_PREVIEW_ORIGINS=true
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/global-city-insights
OPENWEATHER_API_KEY=your_openweather_key
OPENAQ_API_KEY=your_openaq_key
GEODB_API_KEY=your_geodb_rapidapi_key
GEODB_API_HOST=wft-geo-db.p.rapidapi.com
SNAPSHOT_RETENTION_DAYS=15
REFRESH_CRON=*/30 * * * *
